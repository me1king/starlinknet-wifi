generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ActiveSession {
  id          String   @id
  macAddress  String   @unique
  ipAddress   String
  voucherCode String
  deviceType  String   @default("PHONE")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  siteId      String   @default("default-site")
  Site        Site     @relation(fields: [siteId], references: [id])

  @@index([macAddress])
  @@index([voucherCode])
}

model AdminAlert {
  id        String    @id
  type      String
  severity  String    @default("MEDIUM")
  title     String
  message   String
  data      String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  siteId    String    @default("default-site")
  Site      Site      @relation(fields: [siteId], references: [id])

  @@index([read, createdAt])
  @@index([severity])
}

model BalanceAudit {
  id              String   @id
  siteId          String
  expectedRevenue Float
  actualRevenue   Float
  discrepancy     Float
  status          String
  flaggedReason   String?
  auditDate       DateTime @default(now())
  Site            Site     @relation(fields: [siteId], references: [id])
}

model BlacklistedDevice {
  id          String    @id
  macAddress  String
  ipAddress   String?
  reason      String
  severity    String    @default("MEDIUM")
  bannedAt    DateTime  @default(now())
  bannedUntil DateTime?
  bannedBy    String
  notes       String?
  siteId      String    @default("default-site")
  Site        Site      @relation(fields: [siteId], references: [id])

  @@index([bannedAt])
  @@index([macAddress])
}

model BulkVoucher {
  id           String       @id
  voucherCode  String       @unique
  offerId      String
  isUsed       Boolean      @default(false)
  createdAt    DateTime     @default(now())
  siteId       String       @default("default-site")
  VoucherOffer VoucherOffer @relation(fields: [offerId], references: [id])
  Site         Site         @relation(fields: [siteId], references: [id])
}

model DeviceConnection {
  id              String    @id
  macAddress      String
  ipAddress       String
  deviceName      String?
  voucherCode     String?
  status          String    @default("CONNECTED")
  connectedAt     DateTime  @default(now())
  disconnectedAt  DateTime?
  sessionDuration Int?
  dataUsed        Float?
  siteId          String    @default("default-site")
  Site            Site      @relation(fields: [siteId], references: [id])

  @@index([connectedAt])
  @@index([ipAddress])
  @@index([macAddress])
  @@index([voucherCode])
}

model DeviceProfile {
  id            String    @id
  macAddress    String    @unique
  ipAddress     String?
  deviceType    String?
  deviceName    String?
  browserType   String?
  osVersion     String?
  trialUsed     Boolean   @default(false)
  trialUsedAt   DateTime?
  totalSessions Int       @default(0)
  totalDataUsed Float     @default(0)
  totalSpent    Float     @default(0)
  firstSeen     DateTime  @default(now())
  lastSeen      DateTime
  siteId        String    @default("default-site")
  Site          Site      @relation(fields: [siteId], references: [id])

  @@index([deviceType])
  @@index([lastSeen])
  @@index([macAddress])
}

model NetworkDevice {
  id          String    @id
  name        String
  ipAddress   String
  type        String
  status      String    @default("ONLINE")
  lastPing    DateTime?
  siteId      String
  smartPlugId String?
  createdAt   DateTime  @default(now())
  Site        Site      @relation(fields: [siteId], references: [id])
}

model OperationalReport {
  id         String   @id
  siteId     String
  reportType String
  content    String
  sentTo     String
  createdAt  DateTime @default(now())
  Site       Site     @relation(fields: [siteId], references: [id])
}

model Payment {
  id             String        @id
  transactionRef String?       @unique
  idempotencyKey String?       @unique
  amount         Float
  phoneNumber    String?
  macAddress     String?
  ipAddress      String?
  voucherCode    String
  offerId        String?
  status         String        @default("active")
  provisioned    Boolean       @default(false)
  retryCount     Int           @default(0)
  resultDesc     String?
  createdAt      DateTime      @default(now())
  expiresAt      DateTime
  siteId         String        @default("default-site")
  VoucherOffer   VoucherOffer? @relation(fields: [offerId], references: [id])
  Site           Site          @relation(fields: [siteId], references: [id])

  @@index([idempotencyKey])
  @@index([provisioned, status])
  @@index([transactionRef])
  @@index([voucherCode])
}

model PaymentEvent {
  id                String   @id
  externalReference String   @unique
  phoneNumber       String?
  amount            Float?
  status            String
  resultDesc        String?
  macAddress        String?
  ipAddress         String?
  offerId           String?
  createdAt         DateTime @default(now())
  siteId            String   @default("default-site")
  Site              Site     @relation(fields: [siteId], references: [id])
}

model PerformanceLog {
  id            String   @id
  siteId        String
  downloadSpeed Float
  uploadSpeed   Float
  latency       Int
  provider      String
  timestamp     DateTime @default(now())
  Site          Site     @relation(fields: [siteId], references: [id])
}

model Referral {
  id              String   @id
  referrerVoucher String
  refereeMac      String   @unique
  rewardMinutes   Int      @default(30)
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model RevenueSnapshot {
  id                     String   @id
  date                   DateTime @unique
  totalRevenue           Float
  totalSessions          Int
  activeUsers            Int
  totalUsers             Int
  averageSessionDuration Int
  topPackage             String?
  topDeviceType          String?
  siteId                 String   @default("default-site")
  Site                   Site     @relation(fields: [siteId], references: [id])

  @@index([date])
}

model RouterBackup {
  id        String   @id
  siteId    String
  filename  String
  content   String
  createdAt DateTime @default(now())
  Site      Site     @relation(fields: [siteId], references: [id])
}

model SecurityAlert {
  id         String   @id
  siteId     String
  type       String
  message    String
  severity   String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  Site       Site     @relation(fields: [siteId], references: [id])
}

model Site {
  id                String              @id
  name              String
  location          String?
  routerHost        String?
  routerUser        String?
  routerPass        String?
  createdAt         DateTime            @default(now())
  ActiveSession     ActiveSession[]
  AdminAlert        AdminAlert[]
  BalanceAudit      BalanceAudit[]
  BlacklistedDevice BlacklistedDevice[]
  BulkVoucher       BulkVoucher[]
  DeviceConnection  DeviceConnection[]
  DeviceProfile     DeviceProfile[]
  NetworkDevice     NetworkDevice[]
  OperationalReport OperationalReport[]
  Payment           Payment[]
  PaymentEvent      PaymentEvent[]
  PerformanceLog    PerformanceLog[]
  RevenueSnapshot   RevenueSnapshot[]
  RouterBackup      RouterBackup[]
  SecurityAlert     SecurityAlert[]
  Voucher           Voucher[]
  VoucherOffer      VoucherOffer[]
  WhitelistedDevice WhitelistedDevice[]
}

model SpeedTest {
  id        String   @id
  download  Float
  upload    Float
  ping      Float
  isp       String?
  createdAt DateTime @default(now())
}

model SupportMessage {
  id          String   @id
  phoneNumber String
  voucherCode String?
  message     String
  direction   String
  channel     String
  createdAt   DateTime @default(now())
}

model SystemSetting {
  id             String   @id @default("global")
  bannerText     String   @default("")
  bannerType     String   @default("info")
  blockTethering Boolean  @default(false)
  updatedAt      DateTime
}

model Voucher {
  id          String    @id
  code        String    @unique
  durationMin Int
  price       Float
  isUsed      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
  siteId      String    @default("default-site")
  Site        Site      @relation(fields: [siteId], references: [id])

  @@index([code])
}

model VoucherOffer {
  id             String        @id
  name           String
  duration       String
  durationMin    Int
  expiryMode     String        @default("CONTINUOUS")
  price          Float
  maxDevices     Int           @default(1)
  speedLimit     String?
  downloadLimit  String        @default("5M")
  uploadLimit    String        @default("5M")
  dataLimitMB    Int?
  burstLimit     String?
  burstThreshold String?
  burstTime      String?
  allowTethering Boolean       @default(true)
  isSystem       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  siteId         String        @default("default-site")
  BulkVoucher    BulkVoucher[]
  Payment        Payment[]
  Site           Site          @relation(fields: [siteId], references: [id])
}

model WhitelistedDevice {
  id           String    @id
  macAddress   String    @unique
  ipAddress    String?
  name         String
  reason       String?
  freeAccess   Boolean   @default(true)
  allowedUntil DateTime?
  createdAt    DateTime  @default(now())
  createdBy    String
  siteId       String    @default("default-site")
  Site         Site      @relation(fields: [siteId], references: [id])

  @@index([macAddress])
}
